diff --git a/src/compositors/hyprland/hyprland_config_backend.cpp b/src/compositors/hyprland/hyprland_config_backend.cpp
new file mode 100644
index 000000000..c2ba6ba5d
--- /dev/null
+++ b/src/compositors/hyprland/hyprland_config_backend.cpp
@@ -0,0 +1,29 @@
+#include "compositors/hyprland/hyprland_config_backend.h"
+#include "core/process.h"
+#include <json.hpp>
+#include <optional>
+
+namespace compositors::hyprland {
+
+  bool isLua() {
+    static std::optional<bool> cachedIsLua;
+
+    if (cachedIsLua.has_value()) {
+      return *cachedIsLua;
+    }
+
+    const auto result = process::runSync({"hyprctl", "-j", "status"});
+
+    if (result) {
+      try {
+        auto j = nlohmann::json::parse(result.out);
+        cachedIsLua = (j.value("configProvider", "") == "lua");
+      } catch (...) {
+        return false;
+      }
+    }
+
+    return cachedIsLua.value_or(false);
+  }
+
+} // namespace compositors::hyprland
diff --git a/src/compositors/hyprland/hyprland_config_backend.h b/src/compositors/hyprland/hyprland_config_backend.h
new file mode 100644
index 000000000..a3597e5da
--- /dev/null
+++ b/src/compositors/hyprland/hyprland_config_backend.h
@@ -0,0 +1,5 @@
+#pragma once
+
+namespace compositors::hyprland {
+  bool isLua();
+}
diff --git a/src/compositors/hyprland/hyprland_output_backend.cpp b/src/compositors/hyprland/hyprland_output_backend.cpp
index 712a5da64..0326300af 100644
--- a/src/compositors/hyprland/hyprland_output_backend.cpp
+++ b/src/compositors/hyprland/hyprland_output_backend.cpp
@@ -1,9 +1,18 @@
+#include "compositors/hyprland/hyprland_config_backend.h"
 #include "compositors/hyprland/hyprland_output_backend.h"
 
+#include <format>
 #include "core/process.h"
 
 namespace compositors::hyprland {
 
-  bool setOutputPower(bool on) { return process::runAsync({"hyprctl", "dispatch", "dpms", on ? "on" : "off"}); }
+  bool setOutputPower(bool on) {
+    const std::string action = on ? "on" : "off";
+    if (isLua()) {
+      const std::string luaCmd = std::format("hl.dsp.dpms({{ action = \"{}\" }})", action);
+      return process::runAsync({"hyprctl", "dispatch", luaCmd});
+    }
+    return process::runAsync({"hyprctl", "dispatch", "dpms", action});
+  }
 
 } // namespace compositors::hyprland
diff --git a/src/compositors/hyprland/hyprland_workspace_backend.cpp b/src/compositors/hyprland/hyprland_workspace_backend.cpp
index 02407fd7e..bba05d27b 100644
--- a/src/compositors/hyprland/hyprland_workspace_backend.cpp
+++ b/src/compositors/hyprland/hyprland_workspace_backend.cpp
@@ -1,3 +1,4 @@
+#include "compositors/hyprland/hyprland_config_backend.h"
 #include "compositors/hyprland/hyprland_workspace_backend.h"
 
 #include "core/log.h"
@@ -118,7 +119,12 @@ void HyprlandWorkspaceBackend::activate(const std::string& id) {
   }
 
   std::string response;
-  (void)sendRequest(std::format("dispatch workspace {}", id), response);
+  std::string cmd;
+  if (compositors::hyprland::isLua())
+      cmd = std::format("/dispatch hl.dsp.focus({{ workspace = '{}' }})", id);
+  else
+      cmd = std::format("dispatch workspace {}", id);
+  (void)sendRequest(cmd, response);
 }
 
 void HyprlandWorkspaceBackend::activateForOutput(wl_output* /*output*/, const std::string& id) { activate(id); }
